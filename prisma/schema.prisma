generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  MODERATOR
  ADMIN
  HEAD_ADMIN
}

enum ChallengeStatus {
  PENDING
  IN_PROGRESS
  PHASE_1
  PHASE_2
  PASSED
  FAILED
  FUNDED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  IN_PROGRESS
  COMPLETED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  STRIPE
  PAYPAL
  CRYPTO
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ServiceType {
  CHALLENGE_PASSING
  ACCOUNT_MANAGEMENT
  ACCOUNT_GROWTH
}

enum SplitStatus {
  PENDING
  CONFIRMED
  DISPUTED
  REJECTED
}

enum PayoutStatus {
  PENDING
  PAID
  REJECTED
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String?
  passwordHash     String?
  avatar           String?
  image            String?
  role             Role      @default(USER)
  emailVerified    DateTime?
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?
  referralCode     String    @unique @default(cuid())
  referredBy       String?
  referralBalance  Float     @default(0)    // accumulated 20% commission credit from paid referred orders

  // 2FA brute-force protection (CB-7)
  otpAttempts      Int       @default(0)
  otpLockedUntil   DateTime?

  // Staff display name shown to clients (support tickets, chat, etc.)
  // Hides real identity. Falls back to "Support Team" if null.
  staffNickname    String?

  // Signal Hub: nickname/tag shown in Discord when this admin sends a signal.
  // If null, falls back to staffNickname.
  signalNickname   String?

  // Location tracking (updated on each login)
  lastLoginIp      String?
  lastLoginCountry String?
  lastLoginCity    String?
  lastLoginRegion  String?
  lastLoginLat     Float?
  lastLoginLon     Float?
  lastLoginAt      DateTime?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  challenges    Challenge[]
  tickets       SupportTicket[]
  notifications Notification[]
  referrals     Referral[]    @relation("referrer")
  payments      Payment[]
  adminLogs     AdminLog[]
  profitSplits  ProfitSplit[]
  conversations Conversation[]
  referralPayouts ReferralPayout[]

  @@index([email])
  @@index([referralCode])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Order {
  id             String      @id @default(cuid())
  userId         String
  serviceType    ServiceType
  planName       String
  planDetails    Json
  accountSize    String?
  firmName       String?
  status         OrderStatus @default(PENDING_PAYMENT)
  totalAmount    Float
  discountAmount Float       @default(0)
  couponCode     String?
  notes          String?
  proofImage     String?
  paymentNetwork String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge    Challenge?
  payments     Payment[]
  credentials  Credential[]
  profitSplits ProfitSplit[]

  @@index([userId])
  @@index([status])
  @@index([couponCode])
}

model Challenge {
  id              String          @id @default(cuid())
  orderId         String          @unique
  userId          String
  firmName        String
  accountSize     String
  status          ChallengeStatus @default(PENDING)
  currentPhase    Int             @default(1)
  startDate       DateTime?
  endDate         DateTime?
  targetProfit    Float?
  currentProfit   Float           @default(0)
  maxDrawdown     Float?
  currentDrawdown Float           @default(0)
  daysTraded      Int             @default(0)
  winRate         Float           @default(0)
  balance         Float?                             // latest balance from EA
  equity          Float?                             // latest equity from EA
  openProfit      Float?                             // floating P/L of open trades
  totalTrades     Int             @default(0)
  winCount        Int             @default(0)
  openTrades      Int             @default(0)        // number of currently open positions
  proofImages     String[]
  adminNotes      String?
  // Signal routing fields
  riskPct         Float           @default(1.0)
  dailyDDLimit    Float           @default(3.0)
  totalDDLimit    Float           @default(7.0)
  dailyCapPct     Float           @default(3.0)
  allowedPairs    String[]
  isPaused        Boolean         @default(false)
  lastReportedAt  DateTime?                        // set by EA reporter
  eaToken         String?         @unique          // unique connection token per account
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  order        Order            @relation(fields: [orderId], references: [id])
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyStats   DailyStat[]
  deliveries   SignalDelivery[]
  profitSplits ProfitSplit[]

  @@index([userId])
  @@index([status])
}

// ── VPS Signal Distribution ──────────────────────────────────────────
// Signals queued for the Multi-Account Trade Manager (VPS polls these)
model Signal {
  id          String    @id @default(cuid())
  pair        String
  direction   String                          // BUY or SELL
  entry       Float     @default(0)           // 0 = market price
  sl          Float
  tp1         Float
  tp2         Float?
  tp3         Float?
  risk        Float     @default(0)           // 0 = use account defaults
  source      String    @default("admin_panel")
  status      String    @default("pending")   // pending / executed / failed
  sentCount    Int       @default(0)
  failedCount  Int       @default(0)
  errorMessage String?                             // failure reason from VPS
  senderId       String?                           // admin user id who sent this signal
  senderNickname String?                           // snapshot of admin's signalNickname at send time
  createdAt    DateTime  @default(now())
  executedAt   DateTime?

  @@index([status])
  @@index([createdAt])
}

model SignalLog {
  id           String   @id @default(cuid())
  pair         String
  direction    String
  entry        Float?
  sl           Float
  tp1          Float?
  tp2          Float?
  tp3          Float?
  riskPct      Float?
  source       String   @default("discord")
  rawMessage   String?
  totalSent    Int      @default(0)
  totalSkipped Int      @default(0)
  totalFailed  Int      @default(0)
  senderId       String?                            // admin user id who sent this signal
  senderNickname String?                            // snapshot of admin's signalNickname at send time
  sentAt       DateTime @default(now())

  deliveries SignalDelivery[]

  @@index([sentAt])
}

model SignalDelivery {
  id          String   @id @default(cuid())
  signalId    String
  challengeId String
  status      String
  skipReason  String?
  deliveredAt DateTime @default(now())

  signal    SignalLog @relation(fields: [signalId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@index([signalId])
  @@index([challengeId])
}

model DailyStat {
  id          String    @id @default(cuid())
  challengeId String
  date        DateTime
  profit      Float
  loss        Float
  tradesCount Int
  winCount    Int
  lossCount   Int
  notes       String?

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@index([challengeId, date])
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String
  userId          String
  amount          Float
  currency        String        @default("USD")
  method          PaymentMethod
  stripePaymentId String?
  status          String
  invoiceUrl      String?
  createdAt       DateTime      @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([orderId])
  @@index([status])
}

model Credential {
  id          String   @id @default(cuid())
  orderId     String
  platform    String
  server      String?
  loginId     String
  password    String
  notes       String?
  submittedAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Coupon {
  id              String    @id @default(cuid())
  code            String    @unique
  discountPercent Float?
  discountAmount  Float?
  maxUses         Int?
  usedCount       Int       @default(0)
  validFrom       DateTime  @default(now())
  validUntil      DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
}

model SupportTicket {
  id        String       @id @default(cuid())
  userId    String
  subject   String
  message   String
  status    TicketStatus @default(OPEN)
  priority  String       @default("medium")
  responses Json[]       // @deprecated — use TicketReply relation instead
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies TicketReply[]

  @@index([userId])
  @@index([status])
}

// AI-7: Proper relational model for ticket replies (replaces Json[] responses)
model TicketReply {
  id        String   @id @default(cuid())
  ticketId  String
  senderId  String
  senderRole String  // USER, MODERATOR, ADMIN, HEAD_ADMIN
  message   String
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model BlogPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String
  content     String
  coverImage  String?
  author      String
  tags        String[]
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
  @@index([published])
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  avatar    String?
  title     String
  content   String
  rating    Int      @default(5)
  verified  Boolean  @default(false)
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Referral {
  id            String   @id @default(cuid())
  referrerId    String
  referredEmail String
  orderId       String?
  commission    Float    @default(0)
  paid          Boolean  @default(false)
  createdAt     DateTime @default(now())

  referrer User @relation("referrer", fields: [referrerId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@index([referredEmail])
}

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([createdAt])
}

model SiteStats {
  id                String @id @default("global")
  totalClients      Int    @default(0)
  totalPayouts      Float  @default(0)
  challengesPassed  Int    @default(0)
  successRate       Float  @default(0)
  totalFundedAmount Float  @default(0)
}

model ServicePlan {
  id            String   @id @default(cuid())
  name          String
  tier          String
  serviceType   String
  price         Float?
  originalPrice Float?
  priceLabel    String?
  description   String
  features      String[]
  popular       Boolean  @default(false)
  accountSizes  String[]
  sizePricing   Json?    // [{size:"$10,000", price:149, originalPrice:199}, ...]
  guarantee     String?
  successRate   Float?
  deliveryDays  Int?
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([serviceType])
  @@index([isActive, sortOrder])
}

model PropFirm {
  id           String   @id @default(cuid())
  name         String
  logo         String?
  phases       Int      @default(2)
  accountSizes String[]
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model Conversation {
  id          String    @id @default(cuid())
  userId      String
  subject     String?
  lastMessage String?
  lastAt      DateTime  @default(now())
  userUnread  Int       @default(0)
  staffUnread Int       @default(0)
  isClosed    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId])
  @@index([lastAt])
}

model ChatMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  senderRole     String   // USER, MODERATOR, ADMIN, HEAD_ADMIN
  senderName     String?  // snapshot of staffNickname at send time (null for USER role)
  body           String
  read           Boolean  @default(false)
  editedAt       DateTime?    // set when a HEAD_ADMIN edits the message body
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model FAQItem {
  id        String   @id @default(cuid())
  question  String
  answer    String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model TrustStat {
  id        String  @id @default(cuid())
  label     String
  value     Float
  suffix    String?
  prefix    String?
  icon      String
  sortOrder Int     @default(0)
}

model ProfitSplit {
  id           String      @id @default(cuid())
  userId       String
  challengeId  String?
  orderId      String?

  // Payout details
  totalPayout  Float                          // total received from prop firm ($)
  splitPercent Float                          // agreed TMA cut (e.g. 20 = 20%)
  amountDue    Float                          // totalPayout * splitPercent / 100
  amountSent   Float                          // actual amount the client sent
  currency     String      @default("USDT")
  network      String?                        // TRC20, ERC20, BNB, MATIC
  txHash       String?                        // optional on-chain tx hash
  proofImage   String?                        // screenshot URL
  notes        String?

  // Admin review
  status       SplitStatus @default(PENDING)
  adminNote    String?
  reviewedAt   DateTime?

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge    Challenge?  @relation(fields: [challengeId], references: [id])
  order        Order?      @relation(fields: [orderId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([challengeId])
  @@index([orderId])
}

model ReferralPayout {
  id          String       @id @default(cuid())
  userId      String
  amount      Float                                  // amount requested (already debited from User.referralBalance)
  method      String                                 // USDT_TRC20, USDT_ERC20, BNB, MATIC, etc.
  wallet      String                                 // payout wallet address provided by user
  status      PayoutStatus @default(PENDING)
  txHash      String?                                // on-chain tx hash, set when marked PAID
  adminNote   String?                                // admin reason on reject, or any internal note
  processedBy String?                                // admin user id who processed (PAID or REJECTED)
  processedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model HomeService {
  id          String   @id @default(cuid())
  title       String
  description String
  icon        String   @default("Target") // Lucide icon name
  features    String[]
  priceLabel  String   @default("Custom")
  linkHref    String   @default("#pricing")
  linkText    String   @default("View Plans")
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, sortOrder])
}
